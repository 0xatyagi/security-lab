## Fixed Jenkins Pipeline Stage

```groovy
stage('Lint Dockerfile') {
    steps {
        script {
            // Run hadolint with JSON output for parsing
            def exitCode = sh(
                script: """
                    hadolint \
                        --config .hadolint.yaml \
                        --format json \
                        Dockerfile > hadolint-results.json 2>&1
                    echo \$?
                """,
                returnStdout: true
            ).trim().readLines().last().toInteger()

            // Parse results
            def results = readJSON file: 'hadolint-results.json'

            // Count errors (not warnings)
            def errors = results.findAll { it.level == 'error' }
            def warnings = results.findAll { it.level == 'warning' }

            echo "Hadolint: ${errors.size()} errors, ${warnings.size()} warnings"

            // Fail on errors, warn on warnings
            if (errors.size() > 0) {
                errors.each { e ->
                    echo "ERROR: Line ${e.line} — ${e.code}: ${e.message}"
                }
                error("Dockerfile linting failed — ${errors.size()} errors found")
            }

            if (warnings.size() > 0) {
                warnings.each { w ->
                    echo "WARNING: Line ${w.line} — ${w.code}: ${w.message}"
                }
            }
        }
    }
}
```

### Organisation-Wide .hadolint.yaml

```yaml
# .hadolint.yaml — commit this to every repo
failure-threshold: error

# Ignore rules that don't apply to your stack
ignore:
  - DL3008  # apt-get version pinning — handled by base image updates
  - DL3009  # apt-get clean — handled in base image

# Trusted registries — only allow pulls from these
trustedRegistries:
  - 123456789012.dkr.ecr.us-east-1.amazonaws.com
  - python
  - node
```

### Pre-Commit Hook for Local Development

```bash
# .pre-commit-config.yaml
repos:
  - repo: https://github.com/hadolint/hadolint
    rev: v2.14.0
    hooks:
      - id: hadolint
        args: [--config, .hadolint.yaml]
```

Catches issues before they reach Bitbucket. Jenkins is the backstop, not the first line.

