## Detection

```bash
# Find IAM users with ECR permissions — should be zero in production
aws iam list-users --query 'Users[].UserName' --output text | \
    tr '\t' '\n' | while read user; do
        policies=$(aws iam list-user-policies --user-name "$user" \
            --query 'PolicyNames' --output text)
        attached=$(aws iam list-attached-user-policies --user-name "$user" \
            --query 'AttachedPolicies[].PolicyName' --output text)
        if echo "$policies $attached" | grep -qi "ecr"; then
            echo "IAM USER WITH ECR ACCESS: $user"
        fi
    done

# Check Jenkins node IAM role — what does it have access to?
aws iam get-role --role-name jenkins-node-role \
    --query 'Role.AssumeRolePolicyDocument'
```

