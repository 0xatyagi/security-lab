## Fix — Generate and Attach Provenance in Jenkins

```groovy
stage('Generate Provenance') {
    steps {
        script {
            // Build the provenance document
            def provenance = [
                _type: "https://slsa.dev/provenance/v0.2",
                subject: [[
                    name: "${IMAGE_NAME}",
                    digest: [sha256: "${IMAGE_DIGEST}".replace("sha256:", "")]
                ]],
                predicateType: "https://slsa.dev/provenance/v0.2",
                predicate: [
                    builder: [id: "https://jenkins.internal.corp/job/${JOB_NAME}"],
                    buildType: "https://jenkins.io/buildType/docker@v1",
                    invocation: [
                        configSource: [
                            uri: "${BITBUCKET_REPO_URL}",
                            digest: [sha1: "${GIT_COMMIT}"],
                            entryPoint: "Jenkinsfile"
                        ],
                        parameters: [
                            buildNumber: "${BUILD_NUMBER}",
                            jobName: "${JOB_NAME}"
                        ]
                    ],
                    metadata: [
                        buildStartedOn: "${BUILD_TIMESTAMP}",
                        buildFinishedOn: sh(
                            script: 'date -u +"%Y-%m-%dT%H:%M:%SZ"',
                            returnStdout: true
                        ).trim(),
                        completeness: [
                            parameters: true,
                            environment: false,
                            materials: true
                        ],
                        reproducible: false
                    ],
                    materials: [[
                        uri: "${BITBUCKET_REPO_URL}",
                        digest: [sha1: "${GIT_COMMIT}"]
                    ]]
                ]
            ]

            // Write provenance to file
            writeJSON file: 'provenance.json', json: provenance, pretty: 4
        }

        // Attach provenance as cosign attestation
        withCredentials([file(credentialsId: 'cosign-private-key',
                              variable: 'COSIGN_KEY')]) {
            sh """
                COSIGN_PASSWORD='' cosign attest \
                    --key ${COSIGN_KEY} \
                    --predicate provenance.json \
                    --type slsaprovenance \
                    ${IMAGE_NAME}@${IMAGE_DIGEST}
            """
        }
    }
}
```

