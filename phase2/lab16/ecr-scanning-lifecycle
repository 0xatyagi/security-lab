## Detection

```bash
# Audit all repos for missing scan configuration
for repo in $(aws ecr describe-repositories \
    --query 'repositories[].repositoryName' --output text); do
    scan=$(aws ecr describe-repositories \
        --repository-names "$repo" \
        --query 'repositories[0].imageScanningConfiguration.scanOnPush' \
        --output text)
    lifecycle=$(aws ecr get-lifecycle-policy \
        --repository-name "$repo" 2>/dev/null || echo "MISSING")
    echo "$repo: scan_on_push=$scan lifecycle=$lifecycle"
done

# Simulated output:
# webapp: scan_on_push=False lifecycle=MISSING
# auth-service: scan_on_push=False lifecycle=MISSING
# frontend: scan_on_push=True lifecycle=PRESENT
```

